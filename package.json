{
  "name": "metagroup-schema-tools",
  "version": "1.1.2",
  "description": "Metagroup (like vigotech.org) schema tools",
  "main": "src/index.js",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "hooks:install": "npx lefthook install",
    "hooks:run:commit-msg": "npx lefthook run commit-msg",
    "hooks:run:pre-commit": "npx lefthook run pre-commit",
    "hooks:run:pre-commit:all": "npx lefthook run pre-commit --all-files --force",
    "prepare": "npm run hooks:install"
  },
  "repository": "git@github.com:VigoTech/metagroup-schema-tools.git",
  "author": "VigoTech Alliance <vigotechalliance@gmail.com>",
  "contributors": [
    {
      "name": "Sergio Carracedo",
      "email": "hi@sergiocarracedo.es",
      "url": "https://sergiocarracedo.es"
    }
  ],
  "license": "MIT",
  "private": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "jsonschema": "^1.4.0",
    "moment": "^2.29.1",
    "rss-parser": "^3.12.0",
    "sync-request": "^6.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "colors": "^1.3.3",
    "lefthook": "^2.1.6"
  }
}
